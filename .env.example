# Global OpenAI settings (used by pricing-agent)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# PostgreSQL connection used by docker-compose services
DATABASE_URL=postgresql+asyncpg://smart_pricing:smart_pricing@postgres:5432/smart_pricing

# Kafka bootstrap for services
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Dashboard API
API_TITLE=Smart Pricing Agent Dashboard API
API_VERSION=0.1.0
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
LOG_LEVEL=INFO

# Pricing Agent
LOW_STOCK_THRESHOLD=15
MIN_SIGNIFICANT_PRICE_CHANGE_PERCENT=2
PRICING_COOLDOWN_MINUTES=10
MAX_CONCURRENT_DECISIONS=3
PROCESSING_QUEUE_SIZE=100
METRICS_LOG_INTERVAL_SECONDS=60
HEALTHCHECK_FILE=/tmp/pricing-agent.healthy

# Competitor simulator (normal mode)
SIMULATION_MIN_INTERVAL_SECONDS=30
SIMULATION_MAX_INTERVAL_SECONDS=60
SIMULATION_SPEED=1.0

# Competitor simulator (demo mode)
DEMO_SIMULATION_MIN_INTERVAL_SECONDS=5
DEMO_SIMULATION_MAX_INTERVAL_SECONDS=20
DEMO_SIMULATION_SPEED=2.0

# Demand simulator (normal mode)
DEMAND_SIMULATION_MIN_INTERVAL_SECONDS=30
DEMAND_SIMULATION_MAX_INTERVAL_SECONDS=60
DEMAND_SIMULATION_SPEED=1.0

# Demand simulator (demo mode)
DEMO_DEMAND_SIMULATION_MIN_INTERVAL_SECONDS=5
DEMO_DEMAND_SIMULATION_MAX_INTERVAL_SECONDS=20
DEMO_DEMAND_SIMULATION_SPEED=2.0

# Inventory service
INVENTORY_CONSUMER_GROUP=inventory-service
